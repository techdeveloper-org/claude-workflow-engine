#!/bin/bash
# Selective Sync Script for Claude Insight Repository
# Downloads and syncs only claude-insight components
#
# PURPOSE: Quick sync for claude-insight updates
# This bash wrapper delegates to the Python wrapper (sync-insight.py)
#
# USAGE:
#   bash sync-insight
#   ./sync-insight
#
# What it syncs:
#   - All scripts from claude-insight
#   - All policies from claude-insight
#   - Dashboard app (src, templates, static)
#
# Version: 2.0.0 (uses Python wrapper)

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_WRAPPER="$SCRIPT_DIR/sync-insight.py"

if [ ! -f "$PYTHON_WRAPPER" ]; then
    echo "[ERROR] sync-insight.py not found"
    exit 1
fi

# Delegate to Python wrapper (handles cross-platform execution)
python "$PYTHON_WRAPPER"
exit $?
