#!/bin/bash
# Selective Sync Script for Claude Global Library
# Downloads and syncs only skills and agents
#
# PURPOSE: Quick sync for claude-global-library updates
# This bash wrapper delegates to the Python wrapper (sync-library.py)
#
# USAGE:
#   bash sync-library
#   ./sync-library
#
# What it syncs:
#   - All skills from claude-global-library
#   - All agents from claude-global-library
#
# Version: 2.0.0 (uses Python wrapper)

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_WRAPPER="$SCRIPT_DIR/sync-library.py"

if [ ! -f "$PYTHON_WRAPPER" ]; then
    echo "[ERROR] sync-library.py not found"
    exit 1
fi

# Delegate to Python wrapper (handles cross-platform execution)
python "$PYTHON_WRAPPER"
exit $?
