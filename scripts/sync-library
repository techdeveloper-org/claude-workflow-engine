#!/bin/bash
# Selective Sync Script for Claude Global Library
# Downloads and syncs only skills and agents
#
# PURPOSE: Quick sync for claude-global-library updates
# This is a convenience wrapper around hook-downloader.py sync-claude-global-library
#
# USAGE:
#   bash sync-library
#   ./sync-library
#
# What it syncs:
#   - All skills from claude-global-library
#   - All agents from claude-global-library
#
# Version: 1.0.0

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HOOK_DOWNLOADER="$SCRIPT_DIR/hook-downloader.py"

if [ ! -f "$HOOK_DOWNLOADER" ]; then
    echo "[ERROR] hook-downloader.py not found"
    exit 1
fi

# Call hook-downloader with selective sync parameter
python "$HOOK_DOWNLOADER" sync-claude-global-library
exit $?
