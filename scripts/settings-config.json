{
  "_comment": "Template for ~/.claude/settings.json. Replace {CLAUDE_SCRIPTS} with your actual scripts path. On Windows: C:/Users/<username>/.claude/scripts, On Linux/Mac: /home/<username>/.claude/scripts. Or set CLAUDE_SCRIPTS_DIR env var.",
  "permissions": {
    "defaultMode": "default"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python {CLAUDE_SCRIPTS}/3-level-flow.py",
            "timeout": 120
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Write|Edit|NotebookEdit|Bash|Read|Grep|Glob)$",
        "hooks": [
          {
            "type": "command",
            "command": "python {CLAUDE_SCRIPTS}/pre-tool-enforcer.py",
            "timeout": 12
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Write|Edit|NotebookEdit|Bash|TaskCreate|TaskUpdate|Skill|Task)$",
        "hooks": [
          {
            "type": "command",
            "command": "python {CLAUDE_SCRIPTS}/post-tool-tracker.py",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "^(Read|Grep|Glob|WebFetch|WebSearch)$",
        "hooks": [
          {
            "type": "command",
            "command": "python {CLAUDE_SCRIPTS}/post-tool-tracker.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python {CLAUDE_SCRIPTS}/stop-notifier.py",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
