# Claude Workflow Engine - Environment Configuration
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control!

# =============================================================================
# LLM PROVIDER CONFIGURATION (Strategy Pattern)
# =============================================================================

# Primary provider: auto | claude_cli | anthropic
# auto = try all in order: claude_cli -> anthropic
LLM_PROVIDER=auto

# Fallback chain (comma-separated, used when LLM_PROVIDER is not "auto")
# LLM_FALLBACK=claude_cli,anthropic

# --- Claude CLI (uses your Anthropic subscription via 'claude' command) ---
# No configuration needed - auto-detected if 'claude' is in PATH

# --- Anthropic API (direct Claude API, requires API key) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL_BALANCED=claude-sonnet-4-6-20250514
# ANTHROPIC_MODEL_DEEP=claude-opus-4-6-20250514
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages

# --- Voice Mode ---
# VOICE_ENABLED=0  # Set to 0 to disable voice, or touch ~/.claude/.voice-disabled

# --- GitHub (for issue/PR workflow) ---
# CLAUDE_GITHUB_OWNER=techdeveloper-org

# Default label applied to GitHub issues when not specified in pipeline context
GITHUB_DEFAULT_LABEL=feature

# =============================================================================
# JIRA INTEGRATION (for issue tracking workflow)
# =============================================================================
# Supports both Jira Cloud and Jira Server/Data Center

# Jira base URL (required)
# Cloud: https://your-domain.atlassian.net
# Server: https://jira.your-company.com
# JIRA_URL=https://your-domain.atlassian.net

# Jira user email (Cloud) or username (Server)
# JIRA_USER=your-email@company.com

# Jira API token (Cloud) or Personal Access Token (Server)
# Cloud: Generate at https://id.atlassian.com/manage-profile/security/api-tokens
# Server: Generate in Profile > Personal Access Tokens
# JIRA_API_TOKEN=your-api-token

# API version: 3 (Cloud, default) or 2 (Server/Data Center)
# JIRA_API_VERSION=3

# Auth method: basic (default, email:token base64) or bearer (PAT)
# JIRA_AUTH_METHOD=basic

# Default project key for issue creation
# JIRA_DEFAULT_PROJECT=PROJ

# Default issue type when not specified in pipeline context
JIRA_DEFAULT_ISSUE_TYPE=task

# Default branch prefix for Jira-keyed branches (e.g. feature/PROJ-123)
JIRA_DEFAULT_BRANCH_PREFIX=feature

# =============================================================================
# JENKINS INTEGRATION (for CI/CD build management)
# =============================================================================

# Jenkins base URL (required)
# JENKINS_URL=https://jenkins.your-company.com

# Jenkins username
# JENKINS_USER=your-username

# Jenkins API token (NOT password)
# Generate at: Jenkins > Your Name > Configure > API Token > Add New Token
# JENKINS_API_TOKEN=your-api-token

# SSL verification: true (default) or false (for self-signed certs)
# JENKINS_VERIFY_SSL=true

# =============================================================================
# FIGMA INTEGRATION (for design-to-code workflow)
# =============================================================================

# Figma personal access token (required)
# Generate at: Figma > Account Settings > Personal Access Tokens
# FIGMA_ACCESS_TOKEN=figd_...

# Figma team ID (optional, used for team-level component search)
# Find in your Figma team URL: figma.com/files/team/{TEAM_ID}/...
# FIGMA_TEAM_ID=

# =============================================================================
# DEBUG SETTINGS
# =============================================================================

CLAUDE_DEBUG=0

# =============================================================================
# PIPELINE EXECUTION
# =============================================================================

# Hook mode: 1 = Steps 0-9 only (default), 0 = Full pipeline Steps 0-14
CLAUDE_HOOK_MODE=1

# Maximum context tokens budget (per step)
# MAX_CONTEXT_TOKENS=8000

# =============================================================================
# CI/CD FLAGS (GitHub Actions)
# =============================================================================
# These map to GitHub repo variables (Settings > Variables > Actions).
# Default is "false" (disabled). Set to "true" to enable.

ENABLE_CI=false
ENABLE_TESTS=true
ENABLE_LINT=true
ENABLE_COVERAGE=true

# =============================================================================
# INTEGRATION FLAGS (enable/disable pipeline integrations)
# =============================================================================
# Set to "1" to enable, "0" to disable. All default to "0" (disabled).
# Each integration requires its own config section to be filled in above.

ENABLE_JIRA=0
ENABLE_JENKINS=0
ENABLE_SONARQUBE=0
ENABLE_FIGMA=0

# =============================================================================
# GITHUB AUTHENTICATION
# =============================================================================

# GitHub personal access token (required for issue/PR creation)
# Falls back to: gh auth token (GitHub CLI keyring)
# GITHUB_TOKEN=ghp_...

# =============================================================================
# SESSION & CHECKPOINT STORAGE
# =============================================================================

# Session data directory (default: ~/.claude/logs/sessions)
# SESSION_DIR=~/.claude/logs/sessions

# Checkpoint storage directory (default: ~/.claude/logs/sessions/{session_id}/checkpoints)
# CHECKPOINT_DIR=

# =============================================================================
# DIAGRAM OUTPUT DIRECTORIES
# =============================================================================
# Relative to target project root, or supply an absolute path.
# UML_OUTPUT_DIR=uml
# DRAWIO_OUTPUT_DIR=drawio

# =============================================================================
# PATH CONFIGURATION (Cross-Platform)
# =============================================================================
# All paths default to ~/.claude/ using Path.home().
# Override any path with these environment variables:

# Claude directories
# CLAUDE_HOME=~/.claude
# CLAUDE_SCRIPTS_DIR=~/.claude/scripts
# CLAUDE_POLICIES_DIR=~/.claude/policies
# CLAUDE_SETTINGS_FILE=~/.claude/settings.json
# CLAUDE_INSIGHT_DATA_DIR=~/.claude/memory

# =============================================================================
# Runtime Verification (v1.18.0)
# =============================================================================
ENABLE_RUNTIME_VERIFICATION=0
STRICT_RUNTIME_VERIFICATION=0
VERIFICATION_LOG_LEVEL=WARNING
