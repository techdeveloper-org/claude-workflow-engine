# Claude Workflow Engine - Environment Configuration
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control!

# =============================================================================
# LLM PROVIDER CONFIGURATION (Strategy Pattern)
# =============================================================================

# Primary provider: auto (default), ollama, claude_cli, anthropic, openai
# auto = try all in order: ollama -> claude_cli -> anthropic -> openai
LLM_PROVIDER=auto

# Fallback chain (comma-separated, used when LLM_PROVIDER is not "auto")
# LLM_FALLBACK=claude_cli,anthropic,openai

# --- Ollama (local, free, no API key needed) ---
OLLAMA_ENDPOINT=http://localhost:11434/api/generate
OLLAMA_MODEL_FAST=qwen2.5:7b
OLLAMA_MODEL_DEEP=qwen2.5:14b

# --- Claude CLI (uses your Anthropic subscription via 'claude' command) ---
# No configuration needed - auto-detected if 'claude' is in PATH

# --- Anthropic API (direct Claude API, requires API key) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL_BALANCED=claude-sonnet-4-6-20250514
# ANTHROPIC_MODEL_DEEP=claude-opus-4-6-20250514
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages

# --- OpenAI API (requires API key) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL_FAST=gpt-4o-mini
# OPENAI_MODEL_DEEP=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions

# --- Voice Mode ---
# VOICE_ENABLED=0  # Set to 0 to disable voice, or touch ~/.claude/.voice-disabled

# --- GitHub (for issue/PR workflow) ---
# CLAUDE_GITHUB_OWNER=techdeveloper-org

# =============================================================================
# CRITICAL SECURITY SETTINGS
# =============================================================================

# Flask Secret Key - MUST be changed in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_KEY_IN_PRODUCTION

# Admin Credentials - Set secure password on first run
# Leave empty to force password setup on first login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Flask Debug Mode (NEVER enable in production)
FLASK_DEBUG=False
FLASK_ENV=production

# Application Port
FLASK_PORT=5000

# =============================================================================
# SESSION CONFIGURATION
# =============================================================================

# Session timeout in minutes
SESSION_TIMEOUT=30

# Session cookie settings
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# =============================================================================
# CSRF PROTECTION
# =============================================================================

# CSRF Protection Enabled
CSRF_ENABLED=True

# CSRF Token Timeout (seconds)
CSRF_TIME_LIMIT=3600

# =============================================================================
# RATE LIMITING
# =============================================================================

# Global rate limits
RATELIMIT_DEFAULT=200 per day;50 per hour

# Login rate limit
RATELIMIT_LOGIN=5 per minute

# API rate limit
RATELIMIT_API=100 per hour

# Rate limit storage (memory or redis)
RATELIMIT_STORAGE_URL=memory://

# =============================================================================
# SMTP CONFIGURATION (For Alerts)
# =============================================================================

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# =============================================================================
# TWILIO CONFIGURATION (For SMS Alerts)
# =============================================================================

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# =============================================================================
# SECURITY HEADERS
# =============================================================================

# Force HTTPS (disable only for local development)
FORCE_HTTPS=True

# Content Security Policy
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self' 'unsafe-inline'
CSP_STYLE_SRC='self' 'unsafe-inline'

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log to file
LOG_TO_FILE=True
LOG_FILE_PATH=logs/app.log

# Log rotation
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# =============================================================================
# DEVELOPMENT SETTINGS (DO NOT USE IN PRODUCTION)
# =============================================================================

# Set to True only for local development
DEVELOPMENT_MODE=False

# Allow insecure operations (NEVER enable in production)
ALLOW_INSECURE_OPERATIONS=False
