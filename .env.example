# Claude Workflow Engine - Environment Configuration
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control!

# =============================================================================
# LLM PROVIDER CONFIGURATION (Strategy Pattern)
# =============================================================================

# Primary provider: auto (default), ollama, claude_cli, anthropic, openai
# auto = try all in order: ollama -> claude_cli -> anthropic -> openai
LLM_PROVIDER=auto

# Fallback chain (comma-separated, used when LLM_PROVIDER is not "auto")
# LLM_FALLBACK=claude_cli,anthropic,openai

# --- Ollama (local, free, no API key needed) ---
OLLAMA_ENDPOINT=http://localhost:11434/api/generate
OLLAMA_MODEL_FAST=qwen2.5:7b
OLLAMA_MODEL_DEEP=qwen2.5:14b

# --- Claude CLI (uses your Anthropic subscription via 'claude' command) ---
# No configuration needed - auto-detected if 'claude' is in PATH

# --- Anthropic API (direct Claude API, requires API key) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL_BALANCED=claude-sonnet-4-6-20250514
# ANTHROPIC_MODEL_DEEP=claude-opus-4-6-20250514
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages

# --- OpenAI API (requires API key) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL_FAST=gpt-4o-mini
# OPENAI_MODEL_DEEP=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions

# --- Voice Mode ---
# VOICE_ENABLED=0  # Set to 0 to disable voice, or touch ~/.claude/.voice-disabled

# --- GitHub (for issue/PR workflow) ---
# CLAUDE_GITHUB_OWNER=techdeveloper-org

# =============================================================================
# DEBUG SETTINGS
# =============================================================================

CLAUDE_DEBUG=0

# =============================================================================
# PIPELINE EXECUTION
# =============================================================================

# Hook mode: 1 = Steps 0-9 only (default), 0 = Full pipeline Steps 0-14
CLAUDE_HOOK_MODE=1

# Maximum context tokens budget (per step)
# MAX_CONTEXT_TOKENS=8000

# =============================================================================
# GITHUB AUTHENTICATION
# =============================================================================

# GitHub personal access token (required for issue/PR creation)
# Falls back to: gh auth token (GitHub CLI keyring)
# GITHUB_TOKEN=ghp_...

# =============================================================================
# VECTOR DB (Qdrant - RAG Decision Caching)
# =============================================================================

# Local mode (default): no host/port needed, uses ~/.claude/memory/vector_db
# Remote mode: set host + port + optional API key
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_API_KEY=

# =============================================================================
# SESSION & CHECKPOINT STORAGE
# =============================================================================

# Session data directory (default: ~/.claude/logs/sessions)
# SESSION_DIR=~/.claude/logs/sessions

# Checkpoint storage directory (default: ~/.claude/logs/sessions/{session_id}/checkpoints)
# CHECKPOINT_DIR=

# =============================================================================
# PATH CONFIGURATION (Cross-Platform)
# =============================================================================
# All paths default to ~/intel-ai/ or ~/.claude/ using Path.home().
# Override any path with these environment variables:

# Claude directories
# CLAUDE_HOME=~/.claude
# CLAUDE_SCRIPTS_DIR=~/.claude/scripts
# CLAUDE_POLICIES_DIR=~/.claude/policies
# CLAUDE_SETTINGS_FILE=~/.claude/settings.json
# CLAUDE_INSIGHT_DATA_DIR=~/.claude/memory

# Intel AI directories (GPU/NPU/Models)
# INTEL_AI_PATH=~/intel-ai
# INTEL_AI_GPU_PATH=~/intel-ai/gpu
# INTEL_AI_NPU_PATH=~/intel-ai/npu
# INTEL_AI_MODELS_PATH=~/intel-ai/models
# INTEL_AI_GPU_EXE=~/intel-ai/gpu/ollama
# INTEL_AI_NPU_EXE=~/intel-ai/npu/llama-cli-npu

# Inference mode: auto (default), gpu_only, npu_only
# INFERENCE_MODE=auto
